# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Only this chat id is accepted; everything else is ignored silently.
# Message the bot once and watch the logs, or use @userinfobot to find your id.
TELEGRAM_ALLOWED_CHAT_ID=123456789

# ---------------------------------------------------------------------------
# Voice (optional — text chat works without it)
# ---------------------------------------------------------------------------

# ElevenLabs API key, used for voice -> text via Scribe.
ELEVENLABS_API_KEY=

# ElevenLabs speech-to-text model id (default: scribe_v2)
ELEVENLABS_STT_MODEL=scribe_v2

# ---------------------------------------------------------------------------
# Claude / runtime (optional)
# ---------------------------------------------------------------------------

# Working directory Claude's tools operate in (file ops, shell, etc.).
# Base for the future "project switch" feature. Defaults to the launch dir.
CLAUDE_WORKDIR=C:\Users\Rubika Stock\projects\my-project

# Where per-chat session state is persisted (default: <workdir>/.sessions.json)
# SESSIONS_FILE=

# Log verbosity: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Claude authentication:
# The Claude Agent SDK uses your local Claude Code login if you have one.
# Otherwise set an API key here and the SDK will use it.
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Optional browser automation (Playwright MCP) — disabled by default
# ---------------------------------------------------------------------------

# Set to "true" to expose browser tools to Claude (requires @playwright/mcp).
BROWSER_ENABLED=false
# Persistent Chrome user-data-dir (keeps logins). Empty = ephemeral profile.
BROWSER_PROFILE_DIR=
# "true" runs the browser headless (no window). Default: headed.
BROWSER_HEADLESS=false
